PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=medico_db

# ── JWT (use a long random string in production) ──────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Session (use a long random string in production) ──
SESSION_SECRET=change_me_to_another_long_random_string

# ── IoT API Key (sent by ESP32 in X-Api-Key header) ───
IOT_API_KEY=medico-iot-key-2024
