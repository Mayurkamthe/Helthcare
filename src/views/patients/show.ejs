<%- include('../partials/head') %>
<% const currentPage = 'patients'; %>

<div class="flex h-full">
  <%- include('../partials/sidebar') %>
  <div class="flex-1 flex flex-col min-w-0 lg:ml-64">
    <%- include('../partials/topbar') %>
    <main class="flex-1 p-4 sm:p-6 space-y-5 overflow-auto">
      <%- include('../partials/flash') %>

      <!-- Breadcrumb + Actions -->
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-2 text-sm text-slate-500">
          <a href="/patients" class="hover:text-primary-600">Patients</a>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
          <span class="text-slate-800 font-semibold"><%= patient.full_name %></span>
        </div>
        <div class="flex items-center gap-2">
          <% if (patient.device_id) { %>
          <a href="/patients/<%= patient.id %>/live" class="flex items-center gap-1.5 px-3 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg text-sm font-semibold transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
            Live Monitor
          </a>
          <% } %>
          <a href="/reports/patient/<%= patient.id %>" class="flex items-center gap-1.5 px-3 py-2 border border-slate-300 text-slate-700 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m.75 12 3 3m0 0 3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
            PDF Report
          </a>
          <a href="/patients/<%= patient.id %>/edit" class="flex items-center gap-1.5 px-3 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg text-sm font-semibold transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z"/></svg>
            Edit
          </a>
        </div>
      </div>

      <!-- Patient Info Card -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <div class="flex items-center gap-4 mb-5">
            <div class="w-14 h-14 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-2xl flex-shrink-0">
              <%= patient.full_name.charAt(0).toUpperCase() %>
            </div>
            <div>
              <h2 class="text-lg font-bold text-slate-900"><%= patient.full_name %></h2>
              <p class="text-sm text-slate-500"><%= patient.gender || 'N/A' %> &bull; <%= patient.blood_type || 'N/A' %></p>
            </div>
          </div>
          <dl class="space-y-3 text-sm">
            <div class="flex justify-between">
              <dt class="text-slate-500">Date of Birth</dt>
              <dd class="font-medium text-slate-900"><%= patient.date_of_birth ? new Date(patient.date_of_birth).toLocaleDateString() : 'N/A' %></dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-slate-500">Phone</dt>
              <dd class="font-medium text-slate-900"><%= patient.phone_number || 'N/A' %></dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-slate-500">Emergency</dt>
              <dd class="font-medium text-slate-900 text-right max-w-[150px] truncate"><%= patient.emergency_contact || 'N/A' %></dd>
            </div>
            <% if (patient.address) { %>
            <div>
              <dt class="text-slate-500 mb-1">Address</dt>
              <dd class="font-medium text-slate-900"><%= patient.address %></dd>
            </div>
            <% } %>
            <% if (patient.medical_notes) { %>
            <div>
              <dt class="text-slate-500 mb-1">Medical Notes</dt>
              <dd class="text-slate-700 text-xs leading-relaxed bg-slate-50 rounded-lg p-2.5"><%= patient.medical_notes %></dd>
            </div>
            <% } %>
          </dl>
        </div>

        <!-- Device Assignment -->
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <h3 class="font-semibold text-slate-900 mb-4">IoT Device</h3>
          <% if (patient.device_id) { %>
          <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-4">
            <div class="flex items-center gap-2 mb-2">
              <span class="relative flex h-3 w-3">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
              </span>
              <span class="text-sm font-semibold text-green-800">Device Connected</span>
            </div>
            <p class="text-xs font-mono text-green-700 mb-1"><%= patient.device_id %></p>
            <% if (patient.device_assigned_at) { %>
            <p class="text-xs text-green-600">Since: <%= new Date(patient.device_assigned_at).toLocaleString() %></p>
            <% } %>
            <% if (patient.device_expires_at) { %>
            <p class="text-xs text-amber-600 mt-1">Expires: <%= new Date(patient.device_expires_at).toLocaleString() %></p>
            <% } %>
          </div>
          <form action="/patients/<%= patient.id %>/device/unassign" method="POST">
            <button type="submit" class="w-full px-4 py-2 border border-red-300 text-red-600 rounded-lg text-sm font-medium hover:bg-red-50 transition-colors">Unassign Device</button>
          </form>
          <% } else { %>
          <p class="text-sm text-slate-500 mb-4">No device assigned. Assign an ESP32 device to start receiving real-time vitals.</p>
          <form action="/patients/<%= patient.id %>/device/assign" method="POST" class="space-y-3">
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Device ID *</label>
              <input type="text" name="device_id" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" placeholder="ESP32-001" required>
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-600 mb-1">Duration (optional)</label>
              <select name="duration_seconds" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-500">
                <option value="">Permanent</option>
                <option value="3600">1 hour</option>
                <option value="14400">4 hours</option>
                <option value="28800">8 hours</option>
                <option value="86400">24 hours</option>
                <option value="604800">1 week</option>
              </select>
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg text-sm font-semibold transition-colors">Assign Device</button>
          </form>
          <% } %>
        </div>

        <!-- Latest Vitals -->
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-slate-900">Latest Vitals</h3>
            <a href="/patients/<%= patient.id %>/vitals" class="text-xs text-primary-600 hover:underline font-medium">History</a>
          </div>
          <% if (vitals.length > 0) { %>
          <% const lv = vitals[0]; %>
          <div class="space-y-3">
            <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>
                <span class="text-xs font-medium text-slate-600">Heart Rate</span>
              </div>
              <span class="vital-badge <%= lv.heart_rate > 100 || lv.heart_rate < 50 ? 'vital-critical' : 'vital-normal' %>">
                <%= lv.heart_rate %> bpm
              </span>
            </div>
            <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/></svg>
                <span class="text-xs font-medium text-slate-600">SpO2</span>
              </div>
              <span class="vital-badge <%= lv.spo2 < 95 ? 'vital-critical' : lv.spo2 < 97 ? 'vital-warning' : 'vital-normal' %>">
                <%= lv.spo2 %>%
              </span>
            </div>
            <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z"/></svg>
                <span class="text-xs font-medium text-slate-600">Temperature</span>
              </div>
              <span class="vital-badge <%= parseFloat(lv.temperature) >= 38 ? 'vital-critical' : parseFloat(lv.temperature) < 35 ? 'vital-critical' : 'vital-normal' %>">
                <%= parseFloat(lv.temperature).toFixed(1) %>°C
              </span>
            </div>
          </div>
          <p class="text-xs text-slate-400 mt-3"><%= new Date(lv.recorded_at).toLocaleString() %></p>
          <% } else { %>
          <div class="text-center py-6 text-slate-400">
            <svg class="w-10 h-10 mx-auto mb-2 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75Z"/></svg>
            <p class="text-sm">No readings yet</p>
          </div>
          <% } %>

          <!-- Manual Vital Entry -->
          <div class="mt-4 pt-4 border-t border-slate-100">
            <p class="text-xs font-semibold text-slate-500 mb-3 uppercase tracking-wide">Add Manual Reading</p>
            <form action="/patients/<%= patient.id %>/vitals" method="POST" class="space-y-2">
              <div class="grid grid-cols-3 gap-2">
                <div>
                  <label class="block text-xs text-slate-500 mb-1">HR (bpm)</label>
                  <input type="number" name="heart_rate" min="30" max="220" placeholder="72"
                    class="w-full px-2 py-1.5 border border-slate-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-primary-500">
                </div>
                <div>
                  <label class="block text-xs text-slate-500 mb-1">SpO2 (%)</label>
                  <input type="number" name="spo2" min="50" max="100" placeholder="98"
                    class="w-full px-2 py-1.5 border border-slate-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-primary-500">
                </div>
                <div>
                  <label class="block text-xs text-slate-500 mb-1">Temp (°C)</label>
                  <input type="number" name="temperature" min="30" max="45" step="0.1" placeholder="36.6"
                    class="w-full px-2 py-1.5 border border-slate-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-primary-500">
                </div>
              </div>
              <button type="submit" class="w-full py-2 bg-slate-800 hover:bg-slate-900 text-white rounded-lg text-xs font-semibold transition-colors">Record Reading</button>
            </form>
          </div>
        </div>
      </div>

      <!-- Disease Matches -->
      <% if (diseaseMatches && diseaseMatches.length > 0) { %>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-5">
        <div class="flex items-center gap-2 mb-4">
          <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
          <h3 class="font-semibold text-amber-900">Suspected Conditions (Based on Latest Vitals)</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <% diseaseMatches.forEach(m => { %>
          <div class="bg-white border border-amber-200 rounded-lg p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="font-semibold text-slate-900 text-sm"><%= m.disease.name %></span>
              <span class="text-xs font-bold px-2 py-0.5 rounded-full <%= m.confidence >= 0.8 ? 'bg-red-100 text-red-700' : m.confidence >= 0.6 ? 'bg-amber-100 text-amber-700' : 'bg-slate-100 text-slate-600' %>">
                <%= Math.round(m.confidence * 100) %>% match
              </span>
            </div>
            <p class="text-xs text-slate-500 mb-2"><%= m.disease.possibleCauses %></p>
            <p class="text-xs text-slate-500">
              <span class="font-medium">Matched:</span> <%= m.matchedParameters.join(', ').replace(/_/g, ' ') %>
            </p>
          </div>
          <% }) %>
        </div>
        <p class="text-xs text-amber-600 mt-3">
          These are AI-based suggestions only. Clinical diagnosis requires professional evaluation.
        </p>
      </div>
      <% } %>

      <!-- Tabs section -->
      <div class="bg-white rounded-xl border border-slate-200">
        <!-- Tab Nav -->
        <div class="flex border-b border-slate-200 overflow-x-auto">
          <button onclick="switchTab('vitals-tab')" id="btn-vitals-tab" class="tab-btn px-5 py-3.5 text-sm font-medium text-primary-600 border-b-2 border-primary-600 whitespace-nowrap">Vital History</button>
          <button onclick="switchTab('disease-tab')" id="btn-disease-tab" class="tab-btn px-5 py-3.5 text-sm font-medium text-slate-500 hover:text-slate-800 border-b-2 border-transparent whitespace-nowrap">Disease History</button>
          <button onclick="switchTab('alerts-tab')" id="btn-alerts-tab" class="tab-btn px-5 py-3.5 text-sm font-medium text-slate-500 hover:text-slate-800 border-b-2 border-transparent whitespace-nowrap">Alerts</button>
        </div>

        <!-- Vitals Tab -->
        <div id="vitals-tab" class="tab-content p-5">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-slate-900">Recent Vital Readings</h3>
            <a href="/patients/<%= patient.id %>/vitals" class="text-xs text-primary-600 hover:underline font-medium">View all</a>
          </div>
          <% if (vitals.length === 0) { %>
          <p class="text-sm text-slate-400 py-4 text-center">No vital readings recorded</p>
          <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50">
                  <th class="px-4 py-2.5 text-left text-xs font-semibold text-slate-500 uppercase">Date/Time</th>
                  <th class="px-4 py-2.5 text-left text-xs font-semibold text-slate-500 uppercase">Heart Rate</th>
                  <th class="px-4 py-2.5 text-left text-xs font-semibold text-slate-500 uppercase">SpO2</th>
                  <th class="px-4 py-2.5 text-left text-xs font-semibold text-slate-500 uppercase">Temperature</th>
                  <th class="px-4 py-2.5 text-left text-xs font-semibold text-slate-500 uppercase hidden sm:table-cell">Source</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% vitals.forEach(v => { %>
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 text-xs text-slate-500"><%= new Date(v.recorded_at).toLocaleString() %></td>
                  <td class="px-4 py-3">
                    <% if (v.heart_rate) { %>
                    <span class="vital-badge <%= v.heart_rate > 100 || v.heart_rate < 50 ? 'vital-critical' : 'vital-normal' %>"><%= v.heart_rate %> bpm</span>
                    <% } else { %><span class="text-slate-300">--</span><% } %>
                  </td>
                  <td class="px-4 py-3">
                    <% if (v.spo2) { %>
                    <span class="vital-badge <%= v.spo2 < 95 ? 'vital-critical' : 'vital-normal' %>"><%= v.spo2 %>%</span>
                    <% } else { %><span class="text-slate-300">--</span><% } %>
                  </td>
                  <td class="px-4 py-3">
                    <% if (v.temperature) { %>
                    <span class="vital-badge <%= parseFloat(v.temperature) >= 38 ? 'vital-critical' : 'vital-normal' %>"><%= parseFloat(v.temperature).toFixed(1) %>°C</span>
                    <% } else { %><span class="text-slate-300">--</span><% } %>
                  </td>
                  <td class="px-4 py-3 text-xs text-slate-400 font-mono hidden sm:table-cell"><%= v.device_id || '--' %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>

        <!-- Disease History Tab -->
        <div id="disease-tab" class="tab-content p-5 hidden">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-slate-900">Disease History</h3>
            <button onclick="document.getElementById('add-disease-modal').classList.remove('hidden')"
              class="flex items-center gap-1.5 text-sm text-primary-600 font-medium hover:underline">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
              Record Disease
            </button>
          </div>
          <% if (diseases.length === 0) { %>
          <p class="text-sm text-slate-400 py-4 text-center">No disease history recorded</p>
          <% } else { %>
          <div class="space-y-3">
            <% diseases.forEach(d => { %>
            <div class="border border-slate-200 rounded-lg p-4">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                <div>
                  <span class="font-semibold text-slate-900"><%= d.disease_name %></span>
                  <span class="ml-2 px-2 py-0.5 rounded-full text-xs font-semibold <%= d.status === 'ACTIVE' ? 'bg-red-100 text-red-700' : d.status === 'RESOLVED' ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700' %>"><%= d.status %></span>
                </div>
                <span class="text-xs text-slate-400"><%= new Date(d.detected_at).toLocaleDateString() %></span>
              </div>
              <% if (d.possible_causes) { %><p class="text-xs text-slate-500 mb-2"><span class="font-medium">Causes:</span> <%= d.possible_causes %></p><% } %>
              <% if (d.doctor_notes) { %><p class="text-xs text-slate-600 bg-slate-50 p-2 rounded mb-2"><%= d.doctor_notes %></p><% } %>
              <% if (d.status === 'ACTIVE') { %>
              <form action="/patients/<%= patient.id %>/disease-history/<%= d.id %>/clear" method="POST" class="flex gap-2 mt-2">
                <input type="text" name="clearance_notes" placeholder="Clearance notes..." class="flex-1 px-2 py-1 border border-slate-300 rounded text-xs focus:outline-none focus:ring-1 focus:ring-primary-500">
                <button type="submit" class="px-3 py-1 bg-green-600 text-white rounded text-xs font-medium hover:bg-green-700">Mark Resolved</button>
              </form>
              <% } %>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>

        <!-- Alerts Tab -->
        <div id="alerts-tab" class="tab-content p-5 hidden">
          <h3 class="font-semibold text-slate-900 mb-4">Health Alerts</h3>
          <% if (alerts.length === 0) { %>
          <p class="text-sm text-slate-400 py-4 text-center">No alerts for this patient</p>
          <% } else { %>
          <div class="space-y-2">
            <% alerts.forEach(a => { %>
            <div class="flex items-start gap-3 p-3 rounded-lg border <%= a.is_read ? 'border-slate-100 bg-white' : 'border-amber-200 bg-amber-50' %>">
              <div class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0 <%= a.is_read ? 'bg-slate-300' : 'bg-amber-500' %>"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm text-slate-800"><%= a.message %></p>
                <p class="text-xs text-slate-400 mt-1"><%= new Date(a.created_at).toLocaleString() %></p>
              </div>
              <span class="text-xs font-medium px-2 py-0.5 rounded bg-slate-100 text-slate-600 flex-shrink-0"><%= a.alert_type.replace(/_/g, ' ') %></span>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>
</div>

<!-- Add Disease Modal -->
<div id="add-disease-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md">
    <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
      <h3 class="font-semibold text-slate-900">Record Disease</h3>
      <button onclick="document.getElementById('add-disease-modal').classList.add('hidden')" class="text-slate-400 hover:text-slate-800">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form action="/patients/<%= patient.id %>/disease-history" method="POST" class="px-5 py-5 space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Disease Name *</label>
        <input type="text" name="disease_name" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" required placeholder="e.g., Hypertension">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Possible Causes</label>
        <input type="text" name="possible_causes" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" placeholder="e.g., Genetic, lifestyle">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Status</label>
        <select name="status" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-500">
          <option value="ACTIVE">Active</option>
          <option value="MONITORING">Monitoring</option>
          <option value="RESOLVED">Resolved</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Doctor Notes</label>
        <textarea name="doctor_notes" rows="2" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 resize-none" placeholder="Clinical notes..."></textarea>
      </div>
      <div class="flex gap-2 pt-2">
        <button type="submit" class="flex-1 bg-primary-600 hover:bg-primary-700 text-white py-2.5 rounded-lg text-sm font-semibold transition-colors">Save</button>
        <button type="button" onclick="document.getElementById('add-disease-modal').classList.add('hidden')" class="flex-1 border border-slate-300 text-slate-700 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function switchTab(tabId) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden'));
  document.querySelectorAll('.tab-btn').forEach(b => {
    b.classList.remove('text-primary-600', 'border-primary-600');
    b.classList.add('text-slate-500', 'border-transparent');
  });
  document.getElementById(tabId).classList.remove('hidden');
  document.getElementById('btn-' + tabId).classList.add('text-primary-600', 'border-primary-600');
  document.getElementById('btn-' + tabId).classList.remove('text-slate-500', 'border-transparent');
}
</script>

