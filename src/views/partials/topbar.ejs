<header class="sticky top-0 z-40 bg-white border-b border-slate-200 flex items-center justify-between px-4 sm:px-6 h-16">
  <!-- Mobile menu toggle -->
  <button onclick="openSidebar()" class="lg:hidden text-slate-500 hover:text-slate-800 mr-3">
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"/>
    </svg>
  </button>

  <!-- Page Title -->
  <h1 class="text-lg font-semibold text-slate-800 truncate"><%= typeof title !== 'undefined' ? title : 'Medico' %></h1>

  <!-- Right side -->
  <div class="flex items-center gap-2 ml-auto">
    <!-- Alerts Bell -->
    <a href="/alerts" class="relative p-2 text-slate-500 hover:text-slate-800 hover:bg-slate-100 rounded-lg transition-colors">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/>
      </svg>
      <% if (unreadAlerts > 0) { %>
      <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
      <% } %>
    </a>

    <!-- PWA Install button (shown by JS when installable) -->
    <button id="topbar-install-btn" onclick="triggerPwaInstall()" class="hidden p-2 text-slate-500 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors" title="Install app">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
    </button>

    <!-- Avatar -->
    <a href="/profile" class="flex items-center gap-2 p-1.5 rounded-lg hover:bg-slate-100 transition-colors">
      <div class="w-8 h-8 rounded-full bg-primary-600 flex items-center justify-center text-white font-bold text-xs">
        <%= currentDoctor ? currentDoctor.full_name.charAt(0).toUpperCase() : 'D' %>
      </div>
      <span class="hidden sm:block text-sm font-medium text-slate-700 max-w-[120px] truncate"><%= currentDoctor ? currentDoctor.full_name : 'Doctor' %></span>
    </a>
  </div>
</header>

<!-- Mobile overlay -->
<div id="sidebar-overlay" onclick="closeSidebar()" class="hidden fixed inset-0 bg-black/50 z-40 lg:hidden"></div>

<script>
  function openSidebar() {
    document.getElementById('sidebar').classList.remove('-translate-x-full');
    document.getElementById('sidebar-overlay').classList.remove('hidden');
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.add('-translate-x-full');
    document.getElementById('sidebar-overlay').classList.add('hidden');
  }
</script>
<script>
// Expose install trigger for the topbar button
window.addEventListener('beforeinstallprompt', () => {
  const btn = document.getElementById('topbar-install-btn');
  if (btn) btn.classList.remove('hidden');
});
window.addEventListener('appinstalled', () => {
  const btn = document.getElementById('topbar-install-btn');
  if (btn) btn.classList.add('hidden');
});
function triggerPwaInstall() {
  // pwa.js handles the deferred prompt
  const banner = document.getElementById('pwa-install-banner');
  if (banner) { banner.style.display = 'flex'; return; }
  const event = new Event('show-pwa-install');
  window.dispatchEvent(event);
}
</script>
