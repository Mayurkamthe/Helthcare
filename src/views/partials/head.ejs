<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-50">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= typeof title !== 'undefined' ? title + ' | Medico' : 'Medico' %></title>

  <!-- ── PWA Manifest ──────────────────────────────────────────────────── -->
  <link rel="manifest" href="/manifest.json">

  <!-- ── PWA Meta Tags ─────────────────────────────────────────────────── -->
  <meta name="theme-color" content="#0284c7">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="application-name" content="Medico">

  <!-- Apple / iOS -->
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Medico">
  <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152.png">
  <link rel="apple-touch-icon" sizes="192x192" href="/icons/icon-192.png">

  <!-- Microsoft / Windows -->
  <meta name="msapplication-TileImage" content="/icons/icon-144.png">
  <meta name="msapplication-TileColor" content="#0284c7">
  <meta name="msapplication-tap-highlight" content="no">

  <!-- Favicons -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png">
  <link rel="shortcut icon" href="/favicon.png">

  <!-- SEO -->
  <meta name="description" content="Medico — Real-time patient vital signs monitoring powered by IoT devices">
  <meta name="robots" content="noindex, nofollow">

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: {
              50:'#f0f9ff',100:'#e0f2fe',200:'#bae6fd',300:'#7dd3fc',
              400:'#38bdf8',500:'#0ea5e9',600:'#0284c7',700:'#0369a1',
              800:'#075985',900:'#0c4a6e'
            }
          }
        }
      }
    }
  </script>

  <style>
    /* PWA safe-area padding for notched phones */
    body { padding-top: env(safe-area-inset-top); padding-bottom: env(safe-area-inset-bottom); }
    /* Sidebar */
    [x-cloak] { display:none !important; }
    .sidebar-active { background:#0284c7; color:#fff; }
    .sidebar-active svg { stroke:#fff; }
    /* Vital badges */
    .vital-badge { display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:9999px;font-size:11px;font-weight:600; }
    .vital-normal   { background:#dcfce7;color:#166534; }
    .vital-warning  { background:#fef9c3;color:#854d0e; }
    .vital-critical { background:#fee2e2;color:#991b1b; }
    /* Smooth tap highlight removal on mobile */
    * { -webkit-tap-highlight-color:transparent; }
    /* Prevent pull-to-refresh in standalone mode */
    html { overscroll-behavior-y: contain; }
  </style>
</head>
<body class="h-full font-sans antialiased text-slate-800">
